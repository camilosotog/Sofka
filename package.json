{
  "name": "playwright-typescript",
  "version": "1.0.0",
  "description": "Proyecto de testing automatizado con Playwright y TypeScript",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test tests/e2e",
    "test:api": "playwright test tests/api/petstore.spec.ts",
    "test:api:datadriven": "playwright test tests/api/petstore-datadriven.spec.ts",
    "test:api:all": "playwright test tests/api",
    "test:api:report": "playwright test tests/api && playwright show-report",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "codegen": "playwright codegen",
    "report": "playwright show-report",
    "report:api": "playwright show-report"
  },
  "keywords": [
    "playwright",
    "testing",
    "typescript",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
